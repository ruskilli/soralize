# Azure AI Foundry – Sora 2 video generation
# Copy to .env and fill in your values

# Required
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/openai/v1/
# Note: do NOT append /videos — the SDK adds the path automatically

# Optional – defaults shown
SORA_DEPLOYMENT_NAME=sora-2
OUTPUT_DIR=./output
